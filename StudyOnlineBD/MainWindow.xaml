<Window x:Class="StudyOnlineBD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudyOnlineBD"
        mc:Ignorable="d"
        Closed="Window_Closed"
        Title="StadyOnline" Height="450" Width="800">
    <Grid>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Background="LightCyan">
            <TextBlock Text="{Binding ElementName=MainFrame, Path=Content.Title}"
                       HorizontalAlignment="Left" Margin="10 0 0 0"></TextBlock>
            <StackPanel>
                <Button x:Name="ExitButton" Click="ExitButton_Click" Width="70" Height="28" 
                    HorizontalAlignment="Left"
                    Content="Выход" Background="LightSkyBlue"></Button>
                <Button x:Name="CabinetButton" Width="120" Height="29" Margin="0 0 10 0"
                    HorizontalAlignment="Right"
                    Content="Личный кабинет" Background="LightSkyBlue" Click="CabinetButton_Click"></Button>
            </StackPanel>
        </StackPanel>
        <Frame x:Name="MainFrame" ContentRendered="MainFrameContentRendered"  NavigationUIVisibility="Hidden" Grid.Row="1"/>
    </Grid>
</Window>
