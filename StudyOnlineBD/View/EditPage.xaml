<Page x:Class="StudyOnlineBD.View.EditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StudyOnlineBD.View"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EditPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0 0 5 0">
            <TextBlock Margin="0 0 0 10">Название курса:</TextBlock>
            <TextBlock Margin="0 3 0 3">Преподаватель:</TextBlock>
        </StackPanel>
        <StackPanel Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="5 0 0 0" Width="500">
            <TextBox x:Name="TitleTextBox" Margin="0 0 0 10"/>
            <TextBox x:Name="FIOTextBox" IsReadOnly="True" Visibility="Collapsed"/>
            <ComboBox x:Name="FIOComboBox"/>
        </StackPanel>
        <Button Grid.Row="1" Margin="4,27,346,0" Width="250" VerticalAlignment="Top"
                x:Name="AddCourseButton" Click="AddCourseButton_Click" Grid.Column="1">Добавить</Button>
        <Button Grid.Row="1" Margin="261,27,94,0" VerticalAlignment="Top"
                x:Name="OtmenaButton" Click="AddCourseButton_Click" Grid.Column="1">Отмена</Button>
    </Grid>
</Page>
