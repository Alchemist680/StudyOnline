<Page x:Class="StudyOnlineBD.View.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StudyOnlineBD.View"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthPage">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" >
            <StackPanel Orientation="Horizontal" Width="120">
                <TextBlock Text="Логин: "></TextBlock>
                <TextBox Name="TBoxLogin" Width="80"></TextBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Пароль: " Margin="0 10"></TextBlock>
                <PasswordBox Name="PBoxPassword" Width="72" Margin="0 10"></PasswordBox>
            </StackPanel>
            <Button Name="BtnLogin" Click="BtnLogin_Click" Content="Войти"
                    HorizontalAlignment="Center"
                    Padding="30 0" FontWeight="Bold"></Button>
        </StackPanel>
    </Grid>
</Page>
